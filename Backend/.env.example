# Backend Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000

# Database
DATABASE_PATH=./predictions.db
DATABASE_BACKUP=./predictions_backup.db

# Model Configuration
MODEL_DIR=../ml_training/trained_models
DATA_DIR=../ml_training/processed_data
ENSEMBLE_VOTING=majority  # majority, weighted, average

# API Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
MAX_CONTENT_LENGTH=16777216  # 16MB max upload size
REQUEST_TIMEOUT=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Predictions
FAILURE_THRESHOLD_HIGH=0.6
FAILURE_THRESHOLD_MEDIUM=0.3
PREDICTION_CACHE_TTL=300  # seconds
